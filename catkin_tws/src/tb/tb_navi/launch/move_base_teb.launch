<launch>

  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    <rosparam file="$(find agv_navigation)/config/move_base/global_costmap_params.yaml" command="load" />
    <rosparam file="$(find agv_navigation)/config/move_base/teb/move_base_params.yaml" command="load" />
    <rosparam file="$(find agv_navigation)/config/move_base/global_planner_params.yaml" command="load" />
    <rosparam file="$(find agv_navigation)/config/move_base/teb/local_costmap_params.yaml" command="load" />
    <rosparam file="$(find agv_navigation)/config/move_base/teb/teb_local_planner_params.yaml" command="load" />
  </node>

</launch>
